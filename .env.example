# ─── Provider API Keys ───
# Get your keys and fill in the values. Copy this file to .env

# Groq API (priority - fastest)
GROQ_API_KEY=gsk_xxx

# OpenRouter API (fallback - more models)
OPENROUTER_API_KEY=sk-or-v1-xxx

# OmniRouter local API key (used by VS Code extension)
OMNIROUTER_API_KEY=sk-xxx
